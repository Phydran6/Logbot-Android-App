<?xml version="1.0" encoding="utf-8"?>
<!--
    Datei:       activity_setup.xml
    Projekt:     Logbot
    Autor:       Phydran6
    Version:     2.0 - 11.04.2026

    Beschreibung:
    Setup-Layout. Zeigt App-Titel, URL-Feld, Token-Feld, Verbinden-Button und
    QR-Code-Scan-Button. ScrollView damit das Layout auf kleinen Geräten scrollbar ist.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_vertical">

        <!-- App-Name als Titel -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineMedium" />

        <!-- Untertitel / Erklärung -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="40dp"
            android:text="@string/setup_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textAlignment="center" />

        <!-- Instanz-URL Eingabefeld -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilInstanceUrl"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="@string/hint_instance_url">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etInstanceUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:imeOptions="actionNext"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Auth-Token Eingabefeld (als Passwort mit Toggle) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAuthToken"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:hint="@string/hint_auth_token"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAuthToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:imeOptions="actionDone"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Verbinden-Button (primär) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/btn_connect" />

        <!-- Trennlinie -->
        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- QR-Code-Scan-Button (sekundär) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanQr"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_scan_qr" />

    </LinearLayout>
</ScrollView>
